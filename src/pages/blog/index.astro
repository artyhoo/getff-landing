---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Blog — getff';
const description = 'Notes on making conventions executable: enforcement gates, doc drift, and what it takes to keep an AGENTS.md honest.';
---

<BaseLayout title={title} description={description}>
<div class="wrap">
  <header class="hero" style="text-align: left; padding-top: var(--space-m);">
    <h1 style="font-size: var(--step-2);">Blog</h1>
  </header>

  {posts.length === 0 && (
    <p class="fineprint" style="margin-inline: 0;">No posts published yet. <a href="/">Subscribe on the homepage</a> to hear when the first one ships.</p>
  )}

  <ul class="blog-list">
    {posts.map((post) => (
      <li>
        <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <p>{post.data.description}</p>
      </li>
    ))}
  </ul>
</div>
</BaseLayout>
